# Neon Postgres connection string read by the Next.js app (src/lib/neon.ts).
# Also gates the opt-in integration test in src/lib/aggregate-data.integration.test.ts.
DATABASE_URL=postgresql://user:pass@host/db

# Optional: only needed when running the tools/unitbench_publish Typer CLI.
# UNITBENCH_SOURCE_DATABASE_URL=postgresql://user:pass@host/source_db
# UNITBENCH_TARGET_DATABASE_URL=postgresql://user:pass@host/target_db
