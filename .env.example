# Neon Detail Store connection string. Used only by server-side pinned Detail reads.
DATABASE_URL=postgresql://user:pass@host/db

# MotherDuck Analysis Store connection and destination-local bundle identities.
# These are server-only values; never prefix them with NEXT_PUBLIC_.
ANALYSIS_DATABASE_URL=postgresql://user:pass@motherduck-host/analysis_db
# Local development uses this DuckDB database instead of the remote endpoint.
# Keep this server-only and never use a NEXT_PUBLIC_ prefix.
# LOCAL_ANALYSIS_DATABASE_PATH=/absolute/path/to/analysis.duckdb
ANALYSIS_PUBLICATION_DESTINATION_ID=motherduck-analysis
DETAIL_PUBLICATION_DESTINATION_ID=neon-detail
