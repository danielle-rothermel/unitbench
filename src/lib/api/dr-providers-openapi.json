{
  "components": {
    "schemas": {
      "BuildPayloadRequest": {
        "additionalProperties": false,
        "properties": {
          "spec": {
            "$ref": "#/components/schemas/QuerySpec"
          }
        },
        "required": [
          "spec"
        ],
        "title": "BuildPayloadRequest",
        "type": "object"
      },
      "BuildPayloadResponse": {
        "properties": {
          "endpoint_path": {
            "title": "Endpoint Path",
            "type": "string"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          }
        },
        "required": [
          "endpoint_path",
          "payload"
        ],
        "title": "BuildPayloadResponse",
        "type": "object"
      },
      "CostInfo": {
        "additionalProperties": false,
        "properties": {
          "currency": {
            "default": "USD",
            "title": "Currency",
            "type": "string"
          },
          "total_cost": {
            "title": "Total Cost",
            "type": "number"
          }
        },
        "required": [
          "total_cost"
        ],
        "title": "CostInfo",
        "type": "object"
      },
      "FailureClass": {
        "enum": [
          "permanent",
          "transient",
          "rate_limited",
          "resource_exhaustion",
          "unknown"
        ],
        "title": "FailureClass",
        "type": "string"
      },
      "FixtureOutcomeSpec": {
        "additionalProperties": false,
        "properties": {
          "completion_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completion Tokens"
          },
          "failure_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Code"
          },
          "failure_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Message"
          },
          "finish_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "stop",
            "title": "Finish Reason"
          },
          "text": {
            "default": "",
            "title": "Text",
            "type": "string"
          },
          "total_cost": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Cost"
          }
        },
        "title": "FixtureOutcomeSpec",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LlmResponse": {
        "additionalProperties": false,
        "properties": {
          "cost": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CostInfo"
              },
              {
                "type": "null"
              }
            ]
          },
          "finish_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finish Reason"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          },
          "provider_metadata": {
            "additionalProperties": true,
            "title": "Provider Metadata",
            "type": "object"
          },
          "response_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Response Id"
          },
          "text": {
            "title": "Text",
            "type": "string"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TokenUsage"
              },
              {
                "type": "null"
              }
            ]
          },
          "warnings": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/LlmWarning"
            },
            "title": "Warnings",
            "type": "array"
          }
        },
        "required": [
          "text"
        ],
        "title": "LlmResponse",
        "type": "object"
      },
      "LlmWarning": {
        "additionalProperties": false,
        "description": "Conformance or parse observation; the caller decides fatality.",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "severity": {
            "$ref": "#/components/schemas/WarningSeverity",
            "default": "warning"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "LlmWarning",
        "type": "object"
      },
      "MessageRole": {
        "enum": [
          "system",
          "user",
          "assistant",
          "tool"
        ],
        "title": "MessageRole",
        "type": "string"
      },
      "ModelVariance": {
        "additionalProperties": false,
        "description": "Dispersion summary for one model's samples.",
        "properties": {
          "distinct_outputs": {
            "title": "Distinct Outputs",
            "type": "integer"
          },
          "failures": {
            "title": "Failures",
            "type": "integer"
          },
          "max_length": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Length"
          },
          "mean_length": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mean Length"
          },
          "min_length": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min Length"
          },
          "model": {
            "title": "Model",
            "type": "string"
          },
          "samples": {
            "title": "Samples",
            "type": "integer"
          }
        },
        "required": [
          "model",
          "samples",
          "failures",
          "distinct_outputs"
        ],
        "title": "ModelVariance",
        "type": "object"
      },
      "PromptMessage": {
        "additionalProperties": false,
        "properties": {
          "content": {
            "title": "Content",
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/MessageRole"
          }
        },
        "required": [
          "role",
          "content"
        ],
        "title": "PromptMessage",
        "type": "object"
      },
      "ProviderChoice": {
        "additionalProperties": false,
        "description": "Which provider executes the call: scripted fixture or live.",
        "properties": {
          "fixture_outcomes": {
            "items": {
              "$ref": "#/components/schemas/FixtureOutcomeSpec"
            },
            "title": "Fixture Outcomes",
            "type": "array"
          },
          "kind": {
            "$ref": "#/components/schemas/ProviderChoiceKind",
            "default": "fixture"
          }
        },
        "title": "ProviderChoice",
        "type": "object"
      },
      "ProviderChoiceKind": {
        "enum": [
          "fixture",
          "live"
        ],
        "title": "ProviderChoiceKind",
        "type": "string"
      },
      "ProviderFailure": {
        "additionalProperties": false,
        "description": "Primary failure artifact; exceptions carry it.",
        "properties": {
          "code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Code"
          },
          "failure_class": {
            "$ref": "#/components/schemas/FailureClass"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "metadata": {
            "additionalProperties": true,
            "title": "Metadata",
            "type": "object"
          },
          "retryable": {
            "title": "Retryable",
            "type": "boolean"
          }
        },
        "required": [
          "failure_class",
          "message",
          "retryable"
        ],
        "title": "ProviderFailure",
        "type": "object"
      },
      "QueryRequest": {
        "additionalProperties": false,
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/ProviderChoice"
          },
          "spec": {
            "$ref": "#/components/schemas/QuerySpec"
          }
        },
        "required": [
          "spec"
        ],
        "title": "QueryRequest",
        "type": "object"
      },
      "QueryResult": {
        "additionalProperties": false,
        "description": "One provider call: wire payload plus response or failure.",
        "properties": {
          "endpoint_path": {
            "title": "Endpoint Path",
            "type": "string"
          },
          "failure": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ProviderFailure"
              },
              {
                "type": "null"
              }
            ]
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "response": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/LlmResponse"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "endpoint_path",
          "payload"
        ],
        "title": "QueryResult",
        "type": "object"
      },
      "QuerySpec": {
        "additionalProperties": false,
        "description": "Declarative single query: provider kind + model + transcript.",
        "properties": {
          "extra_body": {
            "additionalProperties": true,
            "title": "Extra Body",
            "type": "object"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/PromptMessage"
            },
            "title": "Messages",
            "type": "array"
          },
          "model": {
            "title": "Model",
            "type": "string"
          },
          "provider_kind": {
            "$ref": "#/components/schemas/ServeProviderKind"
          },
          "reasoning": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ReasoningEffort"
              },
              {
                "type": "null"
              }
            ]
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature"
          },
          "token_limit": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Token Limit"
          },
          "top_p": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Top P"
          }
        },
        "required": [
          "provider_kind",
          "model",
          "messages"
        ],
        "title": "QuerySpec",
        "type": "object"
      },
      "ReasoningEffort": {
        "description": "Typed cross-provider reasoning level (see ADR 0001).",
        "enum": [
          "none",
          "minimal",
          "low",
          "medium",
          "high",
          "xhigh"
        ],
        "title": "ReasoningEffort",
        "type": "string"
      },
      "ServeProviderKind": {
        "enum": [
          "openrouter",
          "openai",
          "openai_responses",
          "gemini"
        ],
        "title": "ServeProviderKind",
        "type": "string"
      },
      "TokenUsage": {
        "additionalProperties": false,
        "properties": {
          "completion_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completion Tokens"
          },
          "prompt_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Prompt Tokens"
          },
          "reasoning_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reasoning Tokens"
          },
          "total_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Tokens"
          }
        },
        "title": "TokenUsage",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VarianceRecord": {
        "additionalProperties": false,
        "description": "One sampled call in a variance run (JSONL row).",
        "properties": {
          "completion_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completion Tokens"
          },
          "failure_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Failure Code"
          },
          "finish_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Finish Reason"
          },
          "model": {
            "title": "Model",
            "type": "string"
          },
          "ok": {
            "title": "Ok",
            "type": "boolean"
          },
          "sample_index": {
            "title": "Sample Index",
            "type": "integer"
          },
          "text": {
            "default": "",
            "title": "Text",
            "type": "string"
          },
          "total_cost": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Cost"
          },
          "warning_codes": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Warning Codes",
            "type": "array"
          }
        },
        "required": [
          "model",
          "sample_index",
          "ok"
        ],
        "title": "VarianceRecord",
        "type": "object"
      },
      "VarianceReport": {
        "additionalProperties": false,
        "properties": {
          "models": {
            "items": {
              "type": "string"
            },
            "title": "Models",
            "type": "array"
          },
          "per_model": {
            "items": {
              "$ref": "#/components/schemas/ModelVariance"
            },
            "title": "Per Model",
            "type": "array"
          },
          "prompt": {
            "title": "Prompt",
            "type": "string"
          },
          "records": {
            "items": {
              "$ref": "#/components/schemas/VarianceRecord"
            },
            "title": "Records",
            "type": "array"
          },
          "samples_per_model": {
            "title": "Samples Per Model",
            "type": "integer"
          }
        },
        "required": [
          "prompt",
          "samples_per_model",
          "models",
          "per_model",
          "records"
        ],
        "title": "VarianceReport",
        "type": "object"
      },
      "VarianceRequest": {
        "additionalProperties": false,
        "properties": {
          "models": {
            "items": {
              "type": "string"
            },
            "title": "Models",
            "type": "array"
          },
          "prompt": {
            "title": "Prompt",
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/ProviderChoice"
          },
          "provider_kind": {
            "$ref": "#/components/schemas/ServeProviderKind",
            "default": "openrouter"
          },
          "samples": {
            "default": 3,
            "title": "Samples",
            "type": "integer"
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature"
          }
        },
        "required": [
          "prompt",
          "models"
        ],
        "title": "VarianceRequest",
        "type": "object"
      },
      "WarningSeverity": {
        "enum": [
          "info",
          "warning",
          "critical"
        ],
        "title": "WarningSeverity",
        "type": "string"
      }
    }
  },
  "info": {
    "title": "dr-providers serve",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/build_payload": {
      "post": {
        "operationId": "build_payload_endpoint_build_payload_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuildPayloadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BuildPayloadResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Build Payload Endpoint"
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/query": {
      "post": {
        "operationId": "query_query_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResult"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Query"
      }
    },
    "/variance": {
      "post": {
        "operationId": "variance_variance_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VarianceRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VarianceReport"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Variance"
      }
    }
  }
}
