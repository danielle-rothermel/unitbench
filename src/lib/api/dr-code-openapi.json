{
  "components": {
    "schemas": {
      "CandidateSelectionTrace": {
        "additionalProperties": false,
        "properties": {
          "checks": {
            "items": {
              "$ref": "#/components/schemas/ExtractionTraceNode"
            },
            "title": "Checks",
            "type": "array"
          },
          "compile_ok": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Compile Ok"
          },
          "index": {
            "title": "Index",
            "type": "integer"
          },
          "rejection_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rejection Reason"
          },
          "source": {
            "title": "Source",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/CandidateStatus"
          }
        },
        "required": [
          "index",
          "source",
          "status"
        ],
        "title": "CandidateSelectionTrace",
        "type": "object"
      },
      "CandidateStatus": {
        "enum": [
          "selected",
          "rejected",
          "not_reached"
        ],
        "title": "CandidateStatus",
        "type": "string"
      },
      "CodeParserProfile": {
        "additionalProperties": false,
        "properties": {
          "profile_id": {
            "title": "Profile Id",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "profile_id",
          "version"
        ],
        "title": "CodeParserProfile",
        "type": "object"
      },
      "ExplainRequest": {
        "additionalProperties": false,
        "properties": {
          "parser_version": {
            "default": "v1",
            "title": "Parser Version",
            "type": "string"
          },
          "profile_id": {
            "default": "humaneval-best-effort",
            "title": "Profile Id",
            "type": "string"
          },
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "ExplainRequest",
        "type": "object"
      },
      "ExtractionMethod": {
        "enum": [
          "fenced_code",
          "cleaned_candidate",
          "bare_python",
          "field_marker"
        ],
        "title": "ExtractionMethod",
        "type": "string"
      },
      "ExtractionTrace": {
        "additionalProperties": false,
        "properties": {
          "candidates": {
            "items": {
              "$ref": "#/components/schemas/CandidateSelectionTrace"
            },
            "title": "Candidates",
            "type": "array"
          },
          "extraction_error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extraction Error"
          },
          "extraction_method": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExtractionMethod"
              },
              {
                "type": "null"
              }
            ]
          },
          "profile": {
            "$ref": "#/components/schemas/CodeParserProfile"
          },
          "rationale": {
            "title": "Rationale",
            "type": "string"
          },
          "roots": {
            "items": {
              "$ref": "#/components/schemas/ExtractionTraceNode"
            },
            "title": "Roots",
            "type": "array"
          },
          "selected_candidate_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Selected Candidate Index"
          }
        },
        "required": [
          "profile",
          "roots",
          "candidates",
          "rationale"
        ],
        "title": "ExtractionTrace",
        "type": "object"
      },
      "ExtractionTraceNode": {
        "additionalProperties": false,
        "properties": {
          "after_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "After Text"
          },
          "before_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Before Text"
          },
          "check_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Check Name"
          },
          "children": {
            "items": {
              "$ref": "#/components/schemas/ExtractionTraceNode"
            },
            "title": "Children",
            "type": "array"
          },
          "kind": {
            "$ref": "#/components/schemas/TraceNodeKind"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reason"
          },
          "verdict": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TraceCheckVerdict"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "kind",
          "name"
        ],
        "title": "ExtractionTraceNode",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ProfilesResponse": {
        "properties": {
          "parser_version": {
            "title": "Parser Version",
            "type": "string"
          },
          "profile_ids": {
            "items": {
              "type": "string"
            },
            "title": "Profile Ids",
            "type": "array"
          }
        },
        "required": [
          "profile_ids",
          "parser_version"
        ],
        "title": "ProfilesResponse",
        "type": "object"
      },
      "TraceCheckVerdict": {
        "enum": [
          "pass",
          "fail"
        ],
        "title": "TraceCheckVerdict",
        "type": "string"
      },
      "TraceNodeKind": {
        "enum": [
          "fork",
          "transform",
          "check"
        ],
        "title": "TraceNodeKind",
        "type": "string"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "dr-code serve",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/explain": {
      "post": {
        "operationId": "explain_explain_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExplainRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExtractionTrace"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Explain"
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/profiles": {
      "get": {
        "operationId": "profiles_profiles_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfilesResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Profiles"
      }
    }
  }
}
